# LetzPlay Musix — desktop server configuration template.
# Copy to `.env` (which is git-ignored) and adjust. Flags override these; the shell environment
# overrides the file. Precedence: flag > environment > .env > built-in default.

# Port the web remote is served on.
LETZPLAY_PORT=8090

# Password that grants full control (skip/pause/volume, manage any song).
LETZPLAY_ADMIN_PASSWORD=admin

# Password guests use to join (queue songs, manage their own).
LETZPLAY_GUEST_PASSWORD=party

# Set true to let guests join with ANY password (no guest password required).
LETZPLAY_OPEN=false

# Set true to run without the interactive TUI (for a headless server box / CI).
LETZPLAY_HEADLESS=false

# Max songs each guest may have queued at once (0 = unlimited). Admins are exempt.
LETZPLAY_MAX_PER_USER=0
